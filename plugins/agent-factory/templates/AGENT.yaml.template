# Agent Definition — {{AGENT_NAME}}
# Generated by agent-factory

name: {{AGENT_NAME}}
description: {{AGENT_DESCRIPTION}}

# Model configuration
model: sonnet                    # sonnet | opus | haiku
temperature: 0.7                 # 0.0 - 1.0

# Tools this agent can use (null = all tools)
allowed_tools: null
# allowed_tools:
#   - web_search
#   - web_fetch
#   - read_file
#   - write_file

# Backend preference for dispatch
backend: null                    # glm | openrouter | null (use default)

# Skills this agent ships with
skills:
  # - skill-name

# Workflows this agent uses
workflows:
  # - workflow-name.yaml

# Identity file
soul: SOUL.md

# Memory configuration
memory:
  enabled: true
  directory: memory/

# Dispatch configuration (for running via dispatch command)
dispatch:
  max_turns: 15
  output_format: json
  # system_prompt_override: null   # Use SOUL.md by default
  # mcp_config: null               # Path to MCP config for tool access
