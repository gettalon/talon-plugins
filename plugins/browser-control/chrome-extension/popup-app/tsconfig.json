{
  "compilerOptions": {
    "target": "ES2020",
    "useDefineForClassFields": true,
    "lib": ["ES2020", "DOM", "DOM.Iterable"],
    "module": "ESNext",
    "skipLibCheck": true,
    "moduleResolution": "bundler",
    "allowImportingTsExtensions": true,
    "resolveJsonModule": true,
    "isolatedModules": true,
    "noEmit": true,
    "jsx": "react-jsx",
    "strict": false,
    "paths": {
      "@shared/*": ["../../../mobile/src/lib/*"]
    }
  },
  "include": ["src", "../../../mobile/src/lib/types.ts", "../../../mobile/src/lib/themes.ts"]
}
